generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Food {
  id              Int      @id @default(autoincrement())
  fdcId           Int      @unique
  description     String
  foodClass       String?
  dataType        String?
  publicationDate String?
  ndbNumber       Int?
  isHistoricalReference Boolean @default(false)

  categoryId Int?
  category   FoodCategory? @relation(fields: [categoryId], references: [id])

  nutrients                FoodNutrient[]
  portions                 FoodPortion[]
  inputFoods               InputFood[]
  nutrientConversionFactors NutrientConversionFactor[]
  foodAttributes           FoodAttribute[]

  @@index([categoryId])
}

model FoodCategory {
  id          Int    @id @default(autoincrement())
  code        String? @unique
  description String @unique

  foods Food[]
}

model Nutrient {
  id       Int    @id
  number   String
  name     String
  unitName String
  rank     Int?

  foodNutrients FoodNutrient[]
}

model FoodNutrient {
  id         Int   @id
  amount     Float?
  median     Float?
  min        Float?
  max        Float?
  dataPoints Int?

  foodId     Int
  food       Food @relation(fields: [foodId], references: [id], onDelete: Cascade)

  nutrientId Int
  nutrient   Nutrient @relation(fields: [nutrientId], references: [id])

  derivationCode        String?
  derivationDescription String?
  sourceCode            String?
  sourceDescription     String?

  @@index([foodId])
  @@index([nutrientId])
}

model MeasureUnit {
  id           Int    @id
  name         String
  abbreviation String

  portions FoodPortion[]
}

model FoodPortion {
  id             Int    @id
  foodId         Int
  food           Food   @relation(fields: [foodId], references: [id], onDelete: Cascade)

  measureUnitId  Int?
  measureUnit    MeasureUnit? @relation(fields: [measureUnitId], references: [id])

  amount         Float?
  gramWeight     Float?
  modifier       String?
  sequenceNumber Int?
  minYearAcquired Int?

  @@index([foodId])
}

model InputFood {
  id              Int    @id
  foodId          Int
  food            Food   @relation(fields: [foodId], references: [id], onDelete: Cascade)
  foodDescription String?

  inputFoodFdcId   Int?
  inputFoodDesc    String?
  inputFoodCategory String?

  @@index([foodId])
}

model NutrientConversionFactor {
  id    Int    @id @default(autoincrement())
  foodId Int
  food   Food @relation(fields: [foodId], references: [id], onDelete: Cascade)

  type             String
  proteinValue     Float?
  fatValue         Float?
  carbohydrateValue Float?
  value            Float?

  @@index([foodId])
}

model FoodAttribute {
  id    Int    @id @default(autoincrement())
  foodId Int
  food   Food @relation(fields: [foodId], references: [id], onDelete: Cascade)

  name  String?
  value String?

  @@index([foodId])
}
