# Copy to `.env` and fill in. Generate secrets with: openssl rand -hex 32
#
# This stack runs as microservices behind an nginx gateway (see docker-compose.yml).
# The gateway is the only service that publishes a host port; it listens on :3000,
# the same port the frontend defaults to (VITE_API_URL=http://localhost:3000), so
# the frontend needs no changes.

# ─── External datastores ───────────────────────────────────────────
# Postgres + Redis are NOT run by compose. Point these at your real instances.
# From inside the containers, the host machine is `host.docker.internal`, so a
# DB tunnelled to your host's 5432/5433/6379 is reached as shown below.
# TLS note: the runtime uses node-postgres (@prisma/adapter-pg), which treats
# `sslmode=require` as `verify-full`. Against AWS RDS that fails with
# "self-signed certificate in certificate chain", so do NOT use plain `require`.
# Use ONE of these instead:
#   - Verified (recommended): `?sslmode=verify-full&sslrootcert=/app/certs/rds-combined-ca-bundle.pem`
#     (that CA bundle is mounted into the core/database containers by compose).
#   - Encrypted, no cert check: `?sslmode=no-verify`
# For a local non-TLS Postgres, drop the sslmode param entirely.
DATABASE_URL="postgresql://postgres:postgres@host.docker.internal:5432/food?sslmode=verify-full&sslrootcert=/app/certs/rds-combined-ca-bundle.pem"
AUTH_DATABASE_URL="postgresql://postgres:postgres@host.docker.internal:5433/auth?sslmode=verify-full&sslrootcert=/app/certs/rds-combined-ca-bundle.pem"
REDIS_URL="redis://host.docker.internal:6379"

# ─── Secrets ───────────────────────────────────────────────────────
JWT_SECRET=""
JWT_REFRESH_SECRET=""

# Shared key the agent-service presents (x-internal-key) when calling the
# database-service internal API, and that core/agent/database validate against.
# Must be identical for every service.
INTERNAL_API_KEY=""

# ─── OpenAI ────────────────────────────────────────────────────────
OPENAI_API_KEY=""

# ─── Frontend origin(s), comma-separated ───────────────────────────
# The browser Origin is the frontend (e.g. http://localhost:5173), NOT the gateway.
CORS_ORIGIN=http://localhost:5173

# ─── Logging ───────────────────────────────────────────────────────
# Minimum level emitted by every service (nestjs-pino): trace|debug|info|warn|
# error|fatal. Defaults to `info` if unset. Logs are structured JSON in
# production (NODE_ENV=production) and pretty-printed otherwise.
LOG_LEVEL=info

# ─── Admin bootstrap (used only by `npm run auth:seed` in the core service) ──
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# ─── Agent tuning (REQUIRED) ───────────────────────────────────────
# The agent has NO fallbacks for these: agent/src/config/agent.config.ts throws
# at boot if any is unset or invalid. They must be set here AND are forwarded to
# the agent container in docker-compose.yml. Values below reproduce the formerly
# hardcoded defaults.
AGENT_MAX_ROWS=25                       # hard cap on rows a generated SELECT may return
AGENT_MAX_TOOL_ITERATIONS=10            # max tool-calling loop iterations per request
AGENT_MAX_REQUESTS_PER_DAY=100          # per-user daily request budget
AGENT_RATE_LIMIT_WINDOW_MS=86400000     # window after which that budget resets (24h)
AGENT_MAX_HISTORY_MESSAGES=10           # trailing history messages replayed into context
OPENAI_MODEL=gpt-4o-mini                # chat completion model
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
# Conversation-history page size. REQUIRED by the agent (throws if unset); the
# database service reads the same name but still falls back to 10 on its own.
DEFAULT_HISTORY_LIMIT=10

# ─── Core + Database tuning (OPTIONAL) ─────────────────────────────
# These services keep built-in fallbacks, so every line below is optional and
# merely pins the current default. They are also forwarded to the core/database
# containers in docker-compose.yml, so setting one here overrides the default in
# Docker too; remove a line to fall back to the service's own built-in default.

# Core service (core/src/config/core.config.ts)
BCRYPT_ROUNDS=10                        # bcrypt cost factor for password/token hashing
ACCESS_TOKEN_TTL_SEC=900                # access token lifetime (15m)
REFRESH_TOKEN_TTL_SEC=604800            # refresh token lifetime + cookie maxAge (7d)
ADMIN_TOKEN_TTL_SEC=14400               # admin token lifetime + cookie maxAge (4h)
THROTTLE_SHORT_TTL_MS=60000             # short rate-limit window (1m)
THROTTLE_SHORT_LIMIT=10                 # requests allowed per short window
THROTTLE_LONG_TTL_MS=600000             # long rate-limit window (10m)
THROTTLE_LONG_LIMIT=100                 # requests allowed per long window

# Database service (database/src/config/database.config.ts)
MAX_MESSAGES_PER_CONVERSATION=200       # cap on messages retained per conversation
REDIS_RETRY_STEP_MS=200                 # ioredis reconnect backoff step per attempt
REDIS_RETRY_MAX_MS=5000                 # ioredis reconnect backoff ceiling
