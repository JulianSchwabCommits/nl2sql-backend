PORT=3000

# --- Database ---
# Local dev defaults (used when running with docker-compose.dev.yml)
# Override these to point to an external/production database
DATABASE_URL="postgresql://nl2sql:nl2sql@localhost:5432/nl2sql?schema=public"
AUTH_DATABASE_URL="postgresql://auth:auth@localhost:5433/auth?schema=public"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- AI ---
OPENAI_API_KEY=""

# --- Auth ---
# Generate with: openssl rand -hex 32
JWT_SECRET=""
JWT_REFRESH_SECRET=""

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGIN="http://localhost:5173"
