# datastores
AUTH_DATABASE_URL="postgresql://postgres:postgres@host.docker.internal:5433/auth?sslmode=verify-full&sslrootcert=/app/certs/rds-combined-ca-bundle.pem"
REDIS_URL="redis://host.docker.internal:6379"

JWT_SECRET=""
JWT_REFRESH_SECRET=""

INTERNAL_API_KEY=""

CORS_ORIGIN=http://localhost:5173

# Logging
# trace|debug|info|warn
LOG_LEVEL=info

# Admin bootstrap
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# Agent tuning 
AGENT_MAX_ROWS=25                       
AGENT_MAX_TOOL_ITERATIONS=10            
AGENT_MAX_REQUESTS_PER_DAY=100          
AGENT_RATE_LIMIT_WINDOW_MS=86400000     
AGENT_MAX_HISTORY_MESSAGES=10           
OPENAI_MODEL=gpt-4o-mini                
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
DEFAULT_HISTORY_LIMIT=10


# Core service 
BCRYPT_ROUNDS=10
COOKIE_SECURE=false                     # Set to true in production (HTTPS)
ACCESS_TOKEN_TTL_SEC=900                # (15m)
REFRESH_TOKEN_TTL_SEC=604800            # (7d)
ADMIN_TOKEN_TTL_SEC=14400               # (4h)
THROTTLE_SHORT_TTL_MS=60000             # (1m)
THROTTLE_SHORT_LIMIT=10
THROTTLE_LONG_TTL_MS=600000             # (10m)
THROTTLE_LONG_LIMIT=100                 

# Database service
MAX_MESSAGES_PER_CONVERSATION=200       
REDIS_RETRY_STEP_MS=200                 
REDIS_RETRY_MAX_MS=5000                 
